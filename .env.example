# Shopify Storefront API configuration
# Copy this file to `.env` and fill in your real values, then restart the Expo dev server.
# These EXPO_PUBLIC_ vars are inlined into the app bundle at build time.
# The Storefront access token is a PUBLIC token (safe for client apps) — not your admin password.

# Your shop domain, e.g. ruzza-watch.myshopify.com  (no https://, no trailing slash)
EXPO_PUBLIC_SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com

# Storefront API public access token
# Shopify admin -> Settings -> Apps and sales channels -> Develop apps
#   -> your app -> API credentials -> Storefront API access token
EXPO_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
